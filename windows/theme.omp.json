{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "blocks": [
    {
      "type": "prompt",
      "alignment": "left",
      "segments": [
        {
          "properties": {
            "always_enabled": true,
            "cache_duration": "none"
          },
          "template": "λ",
          "type": "status",
          "style": "plain",
          "foreground_templates": [
            "{{ if .Error }}#e06c75{{ else }}#98c379{{ end }}"
          ]
        },
        {
          "properties": {
            "cache_duration": "none",
            "style": "folder"
          },
          "template": " {{ .Path }} ",
          "foreground": "#56B6C2",
          "type": "path",
          "style": "plain"
        },
        {
          "properties": {
            "branch_icon": "",
            "cache_duration": "none",
            "fetch_status": true
          },
          "template": "[{{ .HEAD }}{{ if .Staging.Changed }}<#00AA00> \u25cf {{ .Staging.String }}</>{{ end }}{{ if .Working.Changed }}<#D75F00> \u25cf {{ .Working.String }}</>{{ end }}]",
          "foreground": "#92C7CF",
          "type": "git",
          "style": "plain"
        }
      ]
    },
    {
      "type": "rprompt",
      "alignment": "right",
      "segments": [
        {
          "properties": {
            "cache_duration": "none"
          },
          "template": "<#505867>[{{ .Env.SHELL_VI_MODE }}]</>",
          "foreground": "#505867",
          "type": "text",
          "style": "plain"
        },
        {
          "properties": {
            "cache_duration": "none",
            "time_format": "15:04"
          },
          "template": "<#505867>[{{ .CurrentDate | date .Format }}]</>",
          "foreground": "#505867",
          "type": "time",
          "style": "plain"
        }
      ]
    }
  ],
  "version": 3,
  "final_space": true
}
